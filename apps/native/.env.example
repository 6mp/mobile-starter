EXPO_PUBLIC_CONVEX_URL=.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=.site

# RevenueCat API Keys
# Get these from: RevenueCat Dashboard → Project → API Keys
# Test keys start with: test_
# Production keys start with: appl_ (iOS) or goog_ (Android)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...

# RevenueCat Entitlement ID
# MUST match exactly what's in RevenueCat Dashboard (case-sensitive, spaces matter!)
# Example: "test-2 Pro", "premium", "pro_annual"
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro

# RevenueCat Offering ID (optional - defaults to "default")
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default
