# Convex Backend Environment Variables Example
# Copy this file to .env.local for local development

# ============================================================================
# RevenueCat Webhook Authentication
# ============================================================================
# Generate with: openssl rand -base64 32
# This token authenticates webhook requests from RevenueCat to your Convex backend
# Set in production with: npx convex env set REVENUECAT_WEBHOOK_AUTH "your-token"
REVENUECAT_WEBHOOK_AUTH=your-generated-webhook-auth-token-here

# ============================================================================
# RevenueCat Entitlement ID
# ============================================================================
# The entitlement ID to check for premium access
# This must match EXACTLY (case-sensitive, spaces matter!):
# 1. Your RevenueCat dashboard entitlement configuration
# 2. Client app (EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID)
#
# Examples: "pro", "premium", "test-2 Pro"
# Set in production with: npx convex env set REVENUECAT_ENTITLEMENT_ID "your-id"
# Default: "pro"
REVENUECAT_ENTITLEMENT_ID=pro

# ============================================================================
# Better Auth Configuration
# ============================================================================
# SITE_URL - Your web app URL (for OAuth callbacks)
# Default: http://localhost:8081
SITE_URL=http://localhost:8081

# NATIVE_APP_URL - Your native app URL scheme (must match app.json scheme)
# Format: {scheme}://
# Default: myrevapp://
NATIVE_APP_URL=myrevapp://

# APPLE_APP_BUNDLE_IDENTIFIER - For Apple Sign In (native only)
# Must match app.json ios.bundleIdentifier
# APPLE_APP_BUNDLE_IDENTIFIER=com.example.myrevapp

# GOOGLE_CLIENT_ID - For Google Sign In
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================================
# Resend Email Service (if using)
# ============================================================================
# RESEND_API_KEY=re_your_api_key_here
